# =============================================================================
# .migrationignore — AI Migration Tool path exclusion list
# =============================================================================
# Syntax is a subset of .gitignore:
#   - Blank lines and lines starting with # are ignored
#   - Lines ending with / match that directory AND everything inside it
#   - Lines starting with ! negate a previous match (allow-list override)
#   - * matches anything within one path segment (not /)
#   - ** matches across path separators (any depth)
#   - Patterns without / match against any single path segment (name or dir)
#   - Patterns with / match against the full relative path
#
# This file is read by ScopingAgent (Stage 1) and ConversionAgent (Stage 5).
# Files matching any active pattern are:
#   - Never scanned or added to the dependency graph
#   - Never included as conversion steps in the Plan Document
#   - Skipped (RULE-011) if they appear in a plan that was created externally
#
# Safe to commit — team-wide settings live here.
# Machine-specific overrides belong in .migrationignore.local (gitignored).
# =============================================================================


# -----------------------------------------------------------------------------
# Dependency directories
# Files inside these dirs are third-party code, never source to migrate.
# -----------------------------------------------------------------------------
node_modules/
.pnpm-store/
.yarn/
.npm/
bower_components/
jspm_packages/
vendor/                    # PHP / Ruby / Go vendor dirs
packages/                  # .NET NuGet restore dir


# -----------------------------------------------------------------------------
# Compiled / generated output — build artefacts, never source
# -----------------------------------------------------------------------------
dist/
build/
out/
.next/
.nuxt/
.output/
.svelte-kit/
.angular/
storybook-static/
public/build/


# -----------------------------------------------------------------------------
# .NET / C# compiled artefacts
# bin/ and obj/ contain compiled assemblies; Debug/ and Release/ are sub-dirs
# created by MSBuild inside bin/ and obj/.
# -----------------------------------------------------------------------------
bin/
obj/
Debug/
Release/
*.dll
*.pdb
*.exe
*.nupkg


# -----------------------------------------------------------------------------
# Debug artefacts and source maps
# Source maps (.map) expose internal paths but are generated files, not source.
# -----------------------------------------------------------------------------
debug/
*.debug.js
*.min.js
*.min.css
*.map


# -----------------------------------------------------------------------------
# Python compiled / virtual environment artefacts
# -----------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.eggs/
.venv/
venv/
env/
.env/
site-packages/


# -----------------------------------------------------------------------------
# Test output and coverage reports
# These are generated artefacts, not source to convert.
# To include test source files in migration, comment out *.spec.* / *.test.*
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
htmlcov/
test-results/
junit.xml
*.snap                     # Jest / Vitest snapshot files


